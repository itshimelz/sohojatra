BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]
DATABASE_URL_LOCAL=postgresql://user:password@localhost:5432/sohojatra_db
REDIS_URL=redis://localhost:6379

JWT_SECRET=your-256-bit-secret
JWT_REFRESH_SECRET=your-256-bit-refresh-secret
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

EC_NID_API_URL=https://api.ec.gov.bd/nid/verify
EC_NID_API_KEY=your-ec-api-key

SSL_SMS_API_URL=https://api.sms.net.bd/sendsms
SSL_SMS_API_KEY=your-sms-net-bd-api-key
SSL_SMS_API_TOKEN=your-sms-net-bd-api-key
SSL_SMS_REPORT_URL=https://api.sms.net.bd/report/request
SSL_SMS_BALANCE_URL=https://api.sms.net.bd/user/balance

GOOGLE_MAPS_API_KEY=your-maps-key

BKASH_APP_KEY=your-bkash-key
BKASH_APP_SECRET=your-bkash-secret

SENDGRID_API_KEY=your-sendgrid-key
FCM_SERVER_KEY=your-fcm-key

# Resend (transactional email — OTP, notifications)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Redis (OTP rate limiting + cache). Provide either REDIS_URL or the discrete fields below.
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your-redis-password


# Rights chatbot (/api/chatbot): configure one or more of GEMINI_API_KEY, GROQ_API_KEY, OPENROUTER_API_KEY.
# The UI lets users pick a provider; the server rejects unconfigured providers.
# Default when the client sends no provider: Gemini if set, else Groq, else OpenRouter.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Optional OpenRouter attribution headers:
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=Sohojatra

# Optional for cloud fallback. Not needed if using local LLaMA only.
OPENAI_API_KEY=not-needed

# External AI microservice (FastAPI on Render/Railway). Used by /api/analyze and /api/ai/warm.
# Example: https://your-service.onrender.com
# RAILWAY_AI_URL=

# -----------------------------------------------------------------------------
# Next.js Frontend (.env.local)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-maps-key

# Optional: MapLibre style URL (JSON). If unset, the concern heat map uses OpenStreetMap raster tiles.
# NEXT_PUBLIC_MAP_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_FIREBASE_CONFIG=your-firebase-config-json