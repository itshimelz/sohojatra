# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── PostgreSQL + pgvector ──────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nagarik_ai
POSTGRES_USER=nagarik
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql+asyncpg://nagarik:your-postgres-password@postgres:5432/nagarik_ai

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── RabbitMQ (optional broker swap) ────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=nagarik-ai

# ── Models ─────────────────────────────────────────────────────────────────────
BANGLABERT_MODEL=csebuetnlp/banglabert
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CLAUDE_MODEL=claude-haiku-4-5

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8001
LOG_LEVEL=info

# ── Thresholds ─────────────────────────────────────────────────────────────────
DUPLICATE_SIMILARITY_THRESHOLD=0.92
DUPLICATE_WINDOW_SIZE=10000
MOB_CLUSTER_MIN_SIZE=5
MOB_POSTING_INTERVAL_SECS=120
RETRAINING_ACCURACY_THRESHOLD=0.85
SCORE_CACHE_TTL=3600
