# ── Anthropic (fallback LLM when Modal is not configured) ─────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Supabase / PostgreSQL ─────────────────────────────────────────────────────
# Use the direct connection (not pooler) — asyncpg requires it
AI_DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<ref>.supabase.co:5432/postgres

POSTGRES_HOST=db.<ref>.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=sohojatra-ai

# ── Models ─────────────────────────────────────────────────────────────────────
BANGLABERT_MODEL=csebuetnlp/banglabert
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CLAUDE_MODEL=claude-haiku-4-5

# ── Fine-tuned model (Phase 2 — Modal) ────────────────────────────────────────
# After `modal deploy ai/serve_model.py`, paste the printed URL here.
# Leave empty to fall back to Claude Haiku for /analyze.
MODAL_API_URL=

# HuggingFace token — needed by Modal container to pull private sohojatra-lora repo
HUGGINGFACE_TOKEN=hf_your_token_here

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8001
LOG_LEVEL=info

# ── Thresholds ─────────────────────────────────────────────────────────────────
DUPLICATE_SIMILARITY_THRESHOLD=0.92
DUPLICATE_WINDOW_SIZE=10000
MOB_CLUSTER_MIN_SIZE=5
MOB_POSTING_INTERVAL_SECS=120
RETRAINING_ACCURACY_THRESHOLD=0.85
SCORE_CACHE_TTL=3600
