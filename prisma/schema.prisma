generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  phoneNumber         String?
  phoneNumberVerified Boolean?

  role       String    @default("citizen")
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?
  onboarded  Boolean   @default(false)
  dob        DateTime?
  education  String?
  passportNumber   String?
  institution      String?
  department       String?
  ministry         String?
  specialization   String?
  trustScore       Float    @default(100)
  reputationPoints Int      @default(0)

  votes         Vote[]
  citizenBadges CitizenBadge[]
  actionLogs    ActionLog[]
  notifications Notification[]

  @@unique([email])
  @@unique([phoneNumber])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum ConcernStatus {
  Submitted
  UnderReview
  ExpertProposed
  GovtApproved
  InProgress
  Resolved
  Rated
}

enum ConcernCategory {
  Infrastructure
  Health
  Education
  Environment
  Corruption
  Safety
  Rights
  Economy
}

enum ProposalStatus {
  Pending
  Approved
  Rejected
}

enum ResearchStatus {
  Open
  UnderReview
  Funded
  Closed
}

enum ModerationStatus {
  Pending
  NeedsReview
  Escalated
  Resolved
}

enum NotificationChannel {
  Push
  Sms
  Email
  InApp
}

enum AwardType {
  ExpertTake
  MostActionable
  BestCited
  LocalVoice
}

model Concern {
  id          String          @id
  title       String
  description String
  status      ConcernStatus   @default(Submitted)
  category    ConcernCategory @default(Infrastructure)
  upvotes     Int             @default(0)
  downvotes   Int             @default(0)
  hasUpvoted  Boolean         @default(false)
  priorityScore Float         @default(0)
  urgencyScore  Float         @default(0)
  isAnonymous   Boolean       @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  authorName  String
  authorId    String?
  locationLat Float
  locationLng Float
  location    String?
  division    String?
  district    String?
  upazila     String?
  photos      Json
  updates     Json

  proposals   Proposal[]
  comments    Comment[]
  analyses    AiAnalysisResult[]
  votes       ConcernVote[]

  @@index([status, createdAt])
  @@index([category, status])
  @@map("concern")
}

model ConcernVote {
  id        String   @id @default(cuid())
  concernId String
  userId    String
  voteType  String   // "up" | "down"
  createdAt DateTime @default(now())

  concern   Concern  @relation(fields: [concernId], references: [id], onDelete: Cascade)

  @@unique([concernId, userId])
  @@index([userId])
  @@index([concernId])
  @@map("concern_vote")
}

model Proposal {
  id              String          @id
  title           String
  body            String
  authorName      String
  authorId        String?
  category        String
  votes           Int             @default(0)
  downvotes       Int             @default(0)
  status          ProposalStatus  @default(Pending)
  aiPriorityScore Float           @default(0)
  isAnonymous     Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  concernId       String?
  concern         Concern?        @relation(fields: [concernId], references: [id], onDelete: SetNull)
  comments        Comment[]
  awards          Award[]

  @@index([status, createdAt])
  @@index([concernId])
  @@map("proposal")
}

model Comment {
  id               String   @id
  body             String
  authorName       String
  authorId         String?
  aiPriorityScore  Float    @default(0)
  upvotes          Int      @default(0)
  downvotes        Int      @default(0)
  quoted           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  proposalId       String?
  concernId        String?
  parentCommentId  String?
  quotedCommentId  String?
  proposal         Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  concern          Concern?  @relation(fields: [concernId], references: [id], onDelete: SetNull)
  parentComment    Comment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies          Comment[] @relation("CommentThread")
  awards           Award[]

  @@index([proposalId, createdAt])
  @@index([concernId, createdAt])
  @@map("comment")
}

model Award {
  id          String    @id
  commentId   String?
  proposalId  String?
  awardType   String
  givenBy     String
  givenById   String?
  title       String?
  description String?
  awardedTo   String?
  value       String?
  createdAt   DateTime  @default(now())
  comment     Comment?  @relation(fields: [commentId], references: [id], onDelete: SetNull)
  proposal    Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([commentId])
  @@index([proposalId])
  @@map("award")
}

model Vote {
  id         String   @id
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String   // "concern" | "proposal" | "comment"
  targetId   String
  value      Int      // +1 or -1
  votedAt    DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([targetId])
  @@map("vote")
}

model Badge {
  id          String         @id
  name        String         @unique
  description String
  criteria    String
  iconKey     String?
  createdAt   DateTime       @default(now())
  earnedBy    CitizenBadge[]

  @@map("badge")
}

model CitizenBadge {
  id       String   @id
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("citizen_badge")
}

model ActionLog {
  id         String   @id
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  concernId  String?
  targetType String
  targetId   String
  action     String
  details    Json?
  loggedAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([userId])
  @@map("action_log")
}

model ResearchProblem {
  id           String         @id
  title        String
  summary      String
  ministry     String
  grantAmount  String
  deadline     String
  status       ResearchStatus @default(Open)
  releasedById String?
  isOpen       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  applications GrantApplication[]

  @@index([status, createdAt])
  @@map("research_problem")
}

model GrantApplication {
  id                String   @id
  researcherName    String
  institution       String
  proposalText      String
  panelScore        Float    @default(0)
  status            String   @default("submitted")
  applicantId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  researchProblemId String
  researchProblem   ResearchProblem @relation(fields: [researchProblemId], references: [id], onDelete: Cascade)
  milestones        Milestone[]

  @@index([researchProblemId])
  @@map("grant_application")
}

model Milestone {
  id                 String   @id
  grantApplicationId String
  title              String
  dueDate            String
  status             String
  deliverableUrl     String?
  paymentAmount      String?
  paidAt             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  grantApplication   GrantApplication @relation(fields: [grantApplicationId], references: [id], onDelete: Cascade)

  @@index([grantApplicationId])
  @@map("milestone")
}

model AssemblyEvent {
  id          String   @id
  title       String
  location    String
  agenda      String?
  eventTime   String
  minutesUrl  String?
  organizedBy String
  organizerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("assembly_event")
}

model Notification {
  id        String              @id
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  concernId String?
  message   String
  channel   NotificationChannel
  isRead    Boolean             @default(false)
  createdAt DateTime            @default(now())

  @@index([userId, isRead])
  @@map("notification")
}

model ModerationFlag {
  id          String            @id
  title       String
  reason      String
  severity    String
  status      ModerationStatus  @default(Pending)
  targetType  String?
  targetId    String?
  reportedBy  String?
  reviewedBy  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, severity])
  @@map("moderation_flag")
}

model Project {
  id                 String   @id
  title              String
  ministry           String
  department         String
  owner              String
  status             String   @default("Planning")
  progress           Int      @default(0)
  deadline           String
  budgetAllocatedBdt BigInt   @default(0)
  budgetSpentBdt     BigInt   @default(0)
  milestones         Json     @default("[]")
  updates            Json     @default("[]")
  followers          Json     @default("[]")
  comments           Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@map("project")
}

model SolutionPlan {
  id                 String   @id
  concernId          String
  title              String
  summary            String
  technicalDocs      Json     @default("[]")
  budgetEstimateBdt  BigInt   @default(0)
  timeline           String
  riskNotes          String
  status             String   @default("Submitted")
  submittedBy        String
  governmentComments String?
  assignedDepartment String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([concernId])
  @@index([status])
  @@map("solution_plan")
}

model ReputationEvent {
  id        String   @id
  userId    String
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("reputation_event")
}

model Thread {
  id        String          @id
  title     String
  createdAt DateTime        @default(now())
  messages  ThreadMessage[]

  @@map("thread")
}

model ThreadMessage {
  id        String   @id
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    String
  text      String
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
  @@map("thread_message")
}

model Disbursement {
  id         String   @id
  project    String
  ministry   String
  amountBdt  BigInt
  status     String   @default("pending")
  releasedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@map("disbursement")
}

model AuthorityMetric {
  id        String   @id
  agency    String
  metric    String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([agency, metric])
  @@map("authority_metric")
}

model AiAnalysisResult {
  id            String   @id
  concernId     String
  sentimentScore Float
  urgencyScore  Float
  categoryTags  Json
  crimeFlags    Json
  analyzedAt    DateTime @default(now())
  concern       Concern  @relation(fields: [concernId], references: [id], onDelete: Cascade)

  @@index([concernId, analyzedAt])
  @@map("ai_analysis_result")
}

model TrainingFeedback {
  id                String   @id @default(cuid())
  text              String
  predictedUrgency  String?
  predictedEmotions Json?
  correctedUrgency  String?
  source            String   @default("comment")
  sourceId          String?
  used              Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([used, createdAt])
  @@map("training_feedback")
}

/// Stores comment embeddings for duplicate detection (pgvector).
/// The `embedding` column uses vector(384) — managed outside Prisma migrations.
model CommentEmbedding {
  commentId BigInt                     @id @map("comment_id")
  embedding Unsupported("vector(384)")
  createdAt DateTime                   @default(now()) @map("created_at")

  @@map("comment_embeddings")
}

/// Stores research document embeddings for RAG (pgvector).
/// The `embedding` column uses vector(384) — managed outside Prisma migrations.
model ResearchDocument {
  id        Int                         @id @default(autoincrement())
  title     String
  content   String
  embedding Unsupported("vector(384)")?
  metadata  Json                        @default("{}")
  createdAt DateTime                    @default(now()) @map("created_at")

  @@map("research_documents")
}
