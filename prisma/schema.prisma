// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─── Authentication (Better Auth) ────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  phoneNumber         String?
  phoneNumberVerified Boolean?

  role       String    @default("citizen")
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  // Extended fields per spec (Part 6: TABLE 1)
  nidHash          String?
  passportNumber   String?
  institution      String?
  department       String?
  ministry         String?
  specialization   String?
  trustScore       Float    @default(100)
  reputationPoints Int      @default(0)

  votes         Vote[]
  citizenBadges CitizenBadge[]
  actionLogs    ActionLog[]
  notifications Notification[]

  @@unique([email])
  @@unique([phoneNumber])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ConcernStatus {
  Submitted
  UnderReview
  ExpertProposed
  GovtApproved
  InProgress
  Resolved
  Rated
}

enum ConcernCategory {
  Infrastructure
  Health
  Education
  Environment
  Corruption
  Safety
  Rights
  Economy
}

enum ProposalStatus {
  Pending
  Approved
  Rejected
}

enum ResearchStatus {
  Open
  UnderReview
  Funded
  Closed
}

enum ModerationStatus {
  Pending
  NeedsReview
  Escalated
  Resolved
}

enum NotificationChannel {
  Push
  Sms
  Email
  InApp
}

enum AwardType {
  ExpertTake
  MostActionable
  BestCited
  LocalVoice
}

// ─── Civic Core ───────────────────────────────────────────────────────────────

model Concern {
  id          String          @id
  title       String
  description String
  status      ConcernStatus   @default(Submitted)
  category    ConcernCategory @default(Infrastructure)
  upvotes     Int             @default(0)
  downvotes   Int             @default(0)
  hasUpvoted  Boolean         @default(false)
  priorityScore Float         @default(0)
  urgencyScore  Float         @default(0)
  isAnonymous   Boolean       @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  authorName  String
  authorId    String?
  locationLat Float
  locationLng Float
  location    String?
  division    String?
  district    String?
  upazila     String?
  photos      Json
  updates     Json

  proposals   Proposal[]
  comments    Comment[]
  analyses    AiAnalysisResult[]

  @@index([status, createdAt])
  @@index([category, status])
  @@map("concern")
}

model Proposal {
  id              String          @id
  title           String
  body            String
  authorName      String
  authorId        String?
  category        String
  votes           Int             @default(0)
  downvotes       Int             @default(0)
  status          ProposalStatus  @default(Pending)
  aiPriorityScore Float           @default(0)
  isAnonymous     Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  concernId       String?
  concern         Concern?        @relation(fields: [concernId], references: [id], onDelete: SetNull)
  comments        Comment[]
  awards          Award[]

  @@index([status, createdAt])
  @@index([concernId])
  @@map("proposal")
}

model Comment {
  id               String   @id
  body             String
  authorName       String
  authorId         String?
  aiPriorityScore  Float    @default(0)
  upvotes          Int      @default(0)
  downvotes        Int      @default(0)
  quoted           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  proposalId       String?
  concernId        String?
  parentCommentId  String?
  quotedCommentId  String?
  proposal         Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  concern          Concern?  @relation(fields: [concernId], references: [id], onDelete: SetNull)
  parentComment    Comment?  @relation("CommentThread", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies          Comment[] @relation("CommentThread")
  awards           Award[]

  @@index([proposalId, createdAt])
  @@index([concernId, createdAt])
  @@map("comment")
}

model Award {
  id          String    @id
  commentId   String?
  proposalId  String?
  awardType   String
  givenBy     String
  givenById   String?
  createdAt   DateTime  @default(now())
  comment     Comment?  @relation(fields: [commentId], references: [id], onDelete: SetNull)
  proposal    Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([commentId])
  @@index([proposalId])
  @@map("award")
}

// ─── Vote Tracking (per-user deduplication, Part 6: TABLE 12) ─────────────────

model Vote {
  id         String   @id
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String   // "concern" | "proposal" | "comment"
  targetId   String
  value      Int      // +1 or -1
  votedAt    DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([targetId])
  @@map("vote")
}

// ─── Badges & Reputation (Part 6: TABLE 19, 20) ───────────────────────────────

model Badge {
  id          String         @id
  name        String         @unique
  description String
  criteria    String
  iconKey     String?
  createdAt   DateTime       @default(now())
  earnedBy    CitizenBadge[]

  @@map("badge")
}

model CitizenBadge {
  id       String   @id
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("citizen_badge")
}

// ─── Immutable Audit Log (Part 6: TABLE 22) ───────────────────────────────────

model ActionLog {
  id         String   @id
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  concernId  String?
  targetType String
  targetId   String
  action     String
  details    Json?
  loggedAt   DateTime @default(now())

  @@index([targetType, targetId])
  @@index([userId])
  @@map("action_log")
}

// ─── Research & Grants (Part 6: TABLES 14–16) ─────────────────────────────────

model ResearchProblem {
  id           String         @id
  title        String
  summary      String
  ministry     String
  grantAmount  String
  deadline     String
  status       ResearchStatus @default(Open)
  releasedById String?
  isOpen       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  applications GrantApplication[]

  @@index([status, createdAt])
  @@map("research_problem")
}

model GrantApplication {
  id                String   @id
  researcherName    String
  institution       String
  proposalText      String
  panelScore        Float    @default(0)
  status            String   @default("submitted")
  applicantId       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  researchProblemId String
  researchProblem   ResearchProblem @relation(fields: [researchProblemId], references: [id], onDelete: Cascade)
  milestones        Milestone[]

  @@index([researchProblemId])
  @@map("grant_application")
}

model Milestone {
  id                 String   @id
  grantApplicationId String
  title              String
  dueDate            String
  status             String
  deliverableUrl     String?
  paymentAmount      String?
  paidAt             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  grantApplication   GrantApplication @relation(fields: [grantApplicationId], references: [id], onDelete: Cascade)

  @@index([grantApplicationId])
  @@map("milestone")
}

// ─── Assembly Events (Part 6: TABLES 17–18) ───────────────────────────────────

model AssemblyEvent {
  id          String   @id
  title       String
  location    String
  agenda      String?
  eventTime   String
  minutesUrl  String?
  organizedBy String
  organizerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("assembly_event")
}

// ─── Notifications (Part 6: TABLE 21) ─────────────────────────────────────────

model Notification {
  id        String              @id
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  concernId String?
  message   String
  channel   NotificationChannel
  isRead    Boolean             @default(false)
  createdAt DateTime            @default(now())

  @@index([userId, isRead])
  @@map("notification")
}

// ─── Moderation (Part 6) ──────────────────────────────────────────────────────

model ModerationFlag {
  id          String            @id
  title       String
  reason      String
  severity    String
  status      ModerationStatus  @default(Pending)
  targetType  String?
  targetId    String?
  reportedBy  String?
  reviewedBy  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([status, severity])
  @@map("moderation_flag")
}

// ─── AI Analysis Results ──────────────────────────────────────────────────────

model AiAnalysisResult {
  id            String   @id
  concernId     String
  sentimentScore Float
  urgencyScore  Float
  categoryTags  Json
  crimeFlags    Json
  analyzedAt    DateTime @default(now())
  concern       Concern  @relation(fields: [concernId], references: [id], onDelete: Cascade)

  @@index([concernId, analyzedAt])
  @@map("ai_analysis_result")
}
